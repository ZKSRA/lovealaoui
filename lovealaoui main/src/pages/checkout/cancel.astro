---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="mx-auto max-w-2xl py-14">
    <div class="rounded-3xl bg-white p-6 text-center shadow-sm ring-1 ring-base-100 sm:p-8">
      <h1 class="text-2xl font-semibold">Checkout canceled</h1>
      <p class="mt-2 text-sm text-base-700">No charge was made. You can come back any time.</p>
      <a href="/my-deck" class="mt-5 inline-flex h-11 items-center justify-center rounded-full bg-base-900 px-5 text-sm font-medium text-white">Back to My Deck</a>
    </div>
  </section>
</BaseLayout>
