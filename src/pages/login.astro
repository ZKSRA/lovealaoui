---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="mx-auto max-w-md py-14">
    <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-base-100 sm:p-8">
      <h1 class="text-2xl font-semibold">Login is coming soon</h1>
      <p class="mt-2 text-sm leading-relaxed text-base-600">
        The public storefront is live first. Secure account access will be re-enabled in the next release.
      </p>
      <a href="/" class="mt-6 inline-flex h-11 items-center justify-center rounded-full bg-base-900 px-5 text-sm font-medium text-white">Back to homepage</a>
    </div>
  </section>
</BaseLayout>
