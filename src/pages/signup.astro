---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="mx-auto max-w-md py-14">
    <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-base-100 sm:p-8">
      <h1 class="text-2xl font-semibold">Instant deck access coming next</h1>
      <p class="mt-2 text-sm leading-relaxed text-base-600">
        We're finalizing account + checkout. For now, explore the homepage preview and launch-ready storefront experience.
      </p>
      <div class="mt-6 flex gap-3">
        <a href="/#featured-product" class="inline-flex h-11 items-center justify-center rounded-full bg-base-900 px-5 text-sm font-medium text-white">View featured deck</a>
        <a href="/#faq" class="inline-flex h-11 items-center justify-center rounded-full border border-base-300 px-5 text-sm font-medium text-base-900">Read FAQ</a>
      </div>
    </div>
  </section>
</BaseLayout>
