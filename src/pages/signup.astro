---
import BaseLayout from "@/layouts/BaseLayout.astro";

if (Astro.locals?.user) {
  return Astro.redirect("/account");
}

const next = Astro.url.searchParams.get("next") ?? "/my-deck";
const errorCode = Astro.url.searchParams.get("error");
---

<BaseLayout>
  <section class="mx-auto max-w-md py-14">
    <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-base-100 sm:p-8">
      <h1 class="text-2xl font-semibold">Create your account</h1>
      <p class="mt-2 text-sm text-base-600">Save purchases and unlock your deck on any device.</p>
      {errorCode && <p class="mt-4 rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">We couldn't create your account. Try another email or verify Supabase settings.</p>}
      <form method="post" action="/api/auth/signup" class="mt-6 space-y-3">
        <input type="hidden" name="next" value={next} />
        <label class="block text-sm">
          <span>Email</span>
          <input name="email" type="email" required class="mt-1 w-full rounded-xl border border-base-300 bg-white px-3 py-2" />
        </label>
        <label class="block text-sm">
          <span>Password</span>
          <input name="password" type="password" minlength="8" required class="mt-1 w-full rounded-xl border border-base-300 bg-white px-3 py-2" />
        </label>
        <button type="submit" class="mt-2 inline-flex h-11 w-full items-center justify-center rounded-full bg-base-900 text-sm font-medium text-white">Sign up</button>
      </form>
      <p class="mt-4 text-sm text-base-600">Already have an account? <a class="underline" href="/login">Log in</a></p>
    </div>
  </section>
</BaseLayout>
