---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getSafeNextPath } from "@/lib/navigation";

if (Astro.locals?.user) {
  return Astro.redirect("/account");
}

const next = getSafeNextPath(Astro.url.searchParams.get("next"));
const errorCode = Astro.url.searchParams.get("error");
const noticeCode = Astro.url.searchParams.get("notice");

const errorMessageMap: Record<string, string> = {
  missing_fields: "Please enter both an email and password.",
  missing_supabase_config:
    "Signup is not configured yet. Set PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY in your Worker environment.",
  signup_unavailable: "Signup service is temporarily unavailable. Please try again shortly.",
  signup_failed: "Signup failed. Check email/password or your Supabase Auth settings.",
};

const errorMessage = errorCode ? errorMessageMap[errorCode] ?? "We couldn't create your account." : null;

const noticeMessageMap: Record<string, string> = {
  check_email:
    "Account created. Check your inbox and confirm your email before logging in.",
};

const noticeMessage = noticeCode
  ? noticeMessageMap[noticeCode] ?? "Please check your email for next steps."
  : null;
---

<BaseLayout>
  <section class="mx-auto max-w-md py-14">
    <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-base-100 sm:p-8">
      <h1 class="text-2xl font-semibold">Create your account</h1>
      <p class="mt-2 text-sm text-base-600">Save purchases and unlock your deck on any device.</p>
      {
        noticeMessage && (
          <p class="mt-4 rounded-xl border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-800">{noticeMessage}</p>
        )
      }
      {
        errorMessage && (
          <p class="mt-4 rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">{errorMessage}</p>
        )
      }
      <form method="post" action="/api/auth/signup" class="mt-6 space-y-3">
        <input type="hidden" name="next" value={next} />
        <label class="block text-sm">
          <span>Email</span>
          <input name="email" type="email" required class="mt-1 w-full rounded-xl border border-base-300 bg-white px-3 py-2" />
        </label>
        <label class="block text-sm">
          <span>Password</span>
          <input name="password" type="password" minlength="8" required class="mt-1 w-full rounded-xl border border-base-300 bg-white px-3 py-2" />
        </label>
        <button type="submit" class="mt-2 inline-flex h-11 w-full items-center justify-center rounded-full bg-base-900 text-sm font-medium text-white">Sign up</button>
      </form>
      <p class="mt-4 text-sm text-base-600">Already have an account? <a class="underline" href={`/login?next=${encodeURIComponent(next)}`}>Log in</a></p>
    </div>
  </section>
</BaseLayout>
