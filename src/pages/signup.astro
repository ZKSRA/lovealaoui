---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getSafeNextPath } from "@/lib/navigation";
import { PREVIEW_DECK_CARDS } from "@/lib/deck-cards";
import logoInline from "@/images/branding/love-alaoui-logo-inline.png";
import heroScene from "@/images/mascots/mochi-mates/mochi-mallow-hero-scene.png";
import mochiShy from "@/images/mascots/mochi-mates/mochi-shy-smile.png";
import mochiListening from "@/images/mascots/mochi-mates/mochi-listening.png";
import mallowReady from "@/images/mascots/mochi-mates/mallow-ready.png";
import mallowHeart from "@/images/mascots/mochi-mates/mallow-heart.png";

if (Astro.locals?.user) {
  return Astro.redirect("/my-deck");
}

const next = getSafeNextPath(Astro.url.searchParams.get("next"));
const errorCode = Astro.url.searchParams.get("error");
const noticeCode = Astro.url.searchParams.get("notice");

const errorMessageMap: Record<string, string> = {
  missing_fields: "Please enter both an email and password.",
  missing_supabase_config:
    "Signup is not configured yet. Set PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY in your Worker environment.",
  signup_unavailable: "Signup service is temporarily unavailable. Please try again shortly.",
  signup_failed: "Signup failed. Check email/password or your Supabase Auth settings.",
};

const errorMessage = errorCode ? errorMessageMap[errorCode] ?? "We couldn't create your account." : null;

const noticeMessageMap: Record<string, string> = {
  check_email:
    "Account created. Check your inbox and confirm your email before logging in.",
};

const noticeMessage = noticeCode
  ? noticeMessageMap[noticeCode] ?? "Please check your email for next steps."
  : null;

const characterArt = {
  Mochi: mochiShy.src,
  Mallow: mallowReady.src,
  "Mochi & Mallow": heroScene.src,
};

const characterAltArt = {
  Mochi: mochiListening.src,
  Mallow: mallowHeart.src,
  "Mochi & Mallow": heroScene.src,
};

const previewDeckCards = PREVIEW_DECK_CARDS.map((card) => ({
  ...card,
  characterImage: characterArt[card.character],
  characterAltImage: characterAltArt[card.character],
}));

const title = "Create Your Love Alaoui Account";
const description = "Create your Love Alaoui account to unlock The Better Conversations Deck, keep purchase access connected, and return to your private conversation ritual.";
---

<BaseLayout title={title} description={description} canonicalPath="/signup">
  <section class="mx-auto grid max-w-5xl gap-5 py-6 sm:py-8 md:grid-cols-[minmax(0,.86fr)_minmax(18rem,.7fr)] md:items-center">
      <div class="relative overflow-hidden rounded-[1.75rem] bg-white/90 p-5 shadow-[0_24px_70px_rgba(216,160,168,0.14)] ring-1 ring-white sm:p-7">
        <div class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-[linear-gradient(90deg,var(--color-rose-600),rgba(232,216,205,0.9))]"></div>
        <div class="relative">
          <p class="text-xs uppercase tracking-[0.22em] text-rose-700">Create your account</p>
          <h1 class="font-editorial mt-2 text-[clamp(2.1rem,6vw,3.1rem)] font-medium leading-[0.95] text-base-900">Unlock the deck.</h1>
          <p class="mt-2 text-sm leading-relaxed text-base-600">One account connects checkout, access, and your private deck.</p>
          {
            noticeMessage && (
              <p class="mt-4 rounded-[1rem] border border-mint-300/40 bg-mint-50 px-3 py-2 text-sm text-base-800" aria-live="polite">{noticeMessage}</p>
            )
          }
          {
            errorMessage && (
              <p class="mt-4 rounded-[1rem] border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700" aria-live="polite">{errorMessage}</p>
            )
          }
          <form method="post" action="/api/auth/signup" class="mt-5 space-y-3">
            <input type="hidden" name="next" value={next} />
            <label class="block text-sm text-base-700">
              <span class="mb-1 block">Email</span>
              <input name="email" type="email" autocomplete="email" spellcheck="false" required class="field-input" />
            </label>
            <label class="block text-sm text-base-700">
              <span class="mb-1 block">Password</span>
              <input name="password" type="password" autocomplete="new-password" minlength="8" required class="field-input" />
            </label>
            <button type="submit" class="inline-flex h-12 w-full items-center justify-center rounded-full bg-rose-600 text-sm font-medium text-white shadow-[0_14px_28px_rgba(225,139,166,0.28)] transition hover:bg-rose-700">Create my account</button>
          </form>
          <p class="mt-4 text-sm text-base-600">Already have an account? <a class="font-medium text-rose-700 underline decoration-rose-300 underline-offset-3" href={`/login?next=${encodeURIComponent(next)}`}>Log in</a></p>
          <div class="mt-4 flex flex-wrap gap-2 text-xs font-medium text-base-600">
            <span class="rounded-full bg-base-50 px-3 py-1.5 ring-1 ring-base-100">120 prompts</span>
            <span class="rounded-full bg-base-50 px-3 py-1.5 ring-1 ring-base-100">$29 once</span>
            <span class="rounded-full bg-base-50 px-3 py-1.5 ring-1 ring-base-100">Private access</span>
          </div>
        </div>
      </div>

      <aside class="relative overflow-hidden rounded-[1.75rem] bg-[linear-gradient(180deg,rgba(255,250,247,0.96),rgba(255,244,247,0.90))] p-4 shadow-[0_24px_70px_rgba(216,160,168,0.12)] ring-1 ring-white/90" aria-labelledby="signup-preview-heading" data-signup-deck>
        <div>
          <div>
            <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">Test cards</p>
            <h2 id="signup-preview-heading" class="font-editorial mt-1 text-[clamp(1.25rem,2.1vw,1.55rem)] font-medium leading-[0.98] text-base-900">Try the feeling first.</h2>
            <p class="mt-1.5 max-w-[16rem] text-sm leading-snug text-base-700">Preview a few cards before you unlock all 120.</p>
          </div>
          <div class="signup-deck-actions" aria-label="Test card controls">
            <button type="button" class="signup-deck-nav" data-signup-prev aria-label="Previous test card">Prev</button>
            <button type="button" class="signup-deck-nav signup-deck-nav-next" data-signup-next aria-label="Next test card">Next</button>
          </div>
        </div>

        <div class="signup-deck-stage" aria-live="polite">
          <div class="signup-card-back signup-card-back-one"></div>
          <div class="signup-card-back signup-card-back-two"></div>
          <article class="signup-card" data-signup-card-shell>
            <div class="signup-card-brand">
              <img src={logoInline.src} alt="Love Alaoui" class="signup-card-logo" />
              <span data-signup-count>1 / {previewDeckCards.length}</span>
            </div>
            <img src={previewDeckCards[0].characterImage} alt="" class="signup-card-character" data-signup-character aria-hidden="true" />
            <p class="signup-card-mode" data-signup-mode>{previewDeckCards[0].mode}</p>
            <h3 class="signup-card-question" data-signup-question>{previewDeckCards[0].question}</h3>
            <div class="signup-card-note">
              <p>Follow-up</p>
              <span data-signup-follow>{previewDeckCards[0].followUp}</span>
            </div>
          </article>
        </div>
      </aside>
  </section>

  <script is:inline define:vars={{ previewDeckCards }}>
    const root = document.querySelector("[data-signup-deck]");
    const cards = previewDeckCards;

    if (root && cards.length > 0) {
      let currentIndex = 0;
      const shell = root.querySelector("[data-signup-card-shell]");
      const count = root.querySelector("[data-signup-count]");
      const character = root.querySelector("[data-signup-character]");
      const mode = root.querySelector("[data-signup-mode]");
      const question = root.querySelector("[data-signup-question]");
      const follow = root.querySelector("[data-signup-follow]");
      const prev = root.querySelector("[data-signup-prev]");
      const next = root.querySelector("[data-signup-next]");

      const render = (nextIndex) => {
        currentIndex = (nextIndex + cards.length) % cards.length;
        const card = cards[currentIndex];
        shell?.classList.remove("is-sliding");
        requestAnimationFrame(() => shell?.classList.add("is-sliding"));

        if (count) count.textContent = `${currentIndex + 1} / ${cards.length}`;
        if (character) character.setAttribute("src", currentIndex % 2 === 0 ? card.characterImage : card.characterAltImage);
        if (mode) mode.textContent = card.mode;
        if (question) question.textContent = card.question;
        if (follow) follow.textContent = card.followUp;
      };

      prev?.addEventListener("click", () => render(currentIndex - 1));
      next?.addEventListener("click", () => render(currentIndex + 1));
    }
  </script>

  <style>
    .signup-deck-stage {
      position: relative;
      min-height: 14.25rem;
      display: grid;
      place-items: center;
      isolation: isolate;
    }

    .signup-card,
    .signup-card-back {
      width: min(100%, 12.8rem);
      min-height: 13.55rem;
      border-radius: 1.25rem;
      transform-origin: 50% 82%;
    }

    .signup-card-back {
      position: absolute;
      border: 1px solid rgba(255, 255, 255, 0.95);
      box-shadow: 0 18px 42px rgba(104, 74, 74, 0.08);
    }

    .signup-card-back-one {
      transform: translate(-0.85rem, 0.75rem) rotate(-8deg);
      background: #f6efea;
    }

    .signup-card-back-two {
      transform: translate(0.9rem, 0.5rem) rotate(7deg);
      background: #fff2f5;
    }

    .signup-card {
      position: relative;
      z-index: 2;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      gap: 0.16rem;
      padding: 0.54rem;
      background:
        radial-gradient(circle at 12% 18%, rgba(255, 197, 217, 0.34), transparent 24%),
        radial-gradient(circle at 88% 18%, rgba(232, 216, 205, 0.48), transparent 22%),
        linear-gradient(180deg, #fffdfb 0%, #fff2f5 100%);
      border: 1px solid rgba(255, 255, 255, 0.98);
      box-shadow: 0 24px 68px rgba(104, 74, 74, 0.15);
    }

    .signup-card.is-sliding {
      animation: signup-card-slide 280ms ease;
    }

    .signup-card-brand {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.65rem;
      color: var(--color-base-500);
      font-size: 0.56rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .signup-card-logo {
      width: 4.25rem;
      height: auto;
      object-fit: contain;
    }

    .signup-card-character {
      display: block;
      width: 2rem;
      height: 2rem;
      object-fit: contain;
      margin: 0.05rem auto 0;
      filter: drop-shadow(0 12px 18px rgba(104, 74, 74, 0.12));
    }

    .signup-card-mode {
      margin-top: 0;
      color: var(--color-rose-700);
      font-size: 0.56rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    .signup-card-question {
      margin-top: 0;
      color: var(--color-base-900);
      font-family: "Newsreader", ui-serif, Georgia, serif;
      font-size: clamp(0.76rem, 1.35vw, 0.9rem);
      font-weight: 500;
      line-height: 1.05;
      overflow-wrap: anywhere;
    }

    .signup-card-note {
      margin-top: auto;
      border-radius: 0.95rem;
      background: rgba(255, 255, 255, 0.78);
      padding: 0.36rem 0.44rem;
      box-shadow: 0 10px 24px rgba(104, 74, 74, 0.06);
    }

    .signup-card-note p {
      color: var(--color-base-500);
      font-size: 0.48rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .signup-card-note span {
      margin-top: 0.3rem;
      display: block;
      color: var(--color-base-800);
      font-size: 0.56rem;
      line-height: 1.16;
      overflow-wrap: anywhere;
    }

    .signup-deck-actions {
      display: flex;
      gap: 0.35rem;
      margin-top: 0.6rem;
      justify-content: flex-end;
    }

    .signup-deck-nav {
      display: inline-flex;
      min-height: 1.85rem;
      min-width: 3.1rem;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.84);
      padding: 0.34rem 0.52rem;
      color: var(--color-base-900);
      font-size: 0.68rem;
      font-weight: 600;
      box-shadow: 0 10px 24px rgba(104, 74, 74, 0.06);
      transition: transform 160ms ease, background-color 160ms ease;
    }

    .signup-deck-nav:hover {
      transform: translateY(-1px);
      background: white;
    }

    .signup-deck-nav-next {
      background: var(--color-rose-600);
      color: white;
    }

    .signup-deck-nav-next:hover {
      background: var(--color-rose-700);
    }

    @keyframes signup-card-slide {
      0% {
        transform: translateY(0.65rem) rotate(-2deg) scale(0.985);
      }
      100% {
        transform: translateY(0) rotate(0deg) scale(1);
      }
    }
  </style>
</BaseLayout>
