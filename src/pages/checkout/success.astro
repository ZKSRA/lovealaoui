---
import BaseLayout from "@/layouts/BaseLayout.astro";
import hugPose from "@/images/mascots/mochi-mates/mochi-mallow-hug.png";
const sessionId = Astro.url.searchParams.get("session_id");
---

<BaseLayout>
  <section class="mx-auto max-w-2xl py-14">
    <div class="rounded-3xl bg-white p-6 text-center shadow-sm ring-1 ring-base-100 sm:p-8">
      <img src={hugPose.src} alt="Mochi and Mallow hugging" class="mx-auto h-28 w-28 object-contain" />
      <p class="mt-3 text-xs font-medium uppercase tracking-[0.22em] text-rose-700">Welcome to Mochi Mates</p>
      <h1 class="mt-2 text-2xl font-semibold">Payment received 🎉</h1>
      <p class="mt-2 text-sm text-base-700">Mochi &amp; Mallow saved your spot. It can take a few seconds for your deck access to appear inside My Rituals.</p>
      {sessionId && <p class="mt-3 text-xs text-base-500">Session: {sessionId}</p>}
      <a href="/my-deck" class="mt-5 inline-flex h-11 items-center justify-center rounded-full bg-base-900 px-5 text-sm font-medium text-white">Open My Rituals</a>
    </div>
  </section>
</BaseLayout>
