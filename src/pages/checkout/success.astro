---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import kissScene from "@/images/mascots/mochi-mates/mochi-mallow-kiss.png";
import hugPose from "@/images/mascots/mochi-mates/mochi-mallow-hug.png";

const title = "Deck Unlocked | Love Alaoui";
const description = "Your Better Conversations Deck is unlocked. Open My Deck to start your first Love Alaoui conversation ritual.";
---

<BaseLayout title={title} description={description} canonicalPath="/checkout/success" robots="noindex, follow">
  <section class="mx-auto max-w-4xl py-12">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,.9fr)_minmax(20rem,.82fr)] lg:items-center">
      <div class="relative overflow-hidden rounded-[2rem] bg-[linear-gradient(180deg,rgba(255,246,248,0.96),rgba(255,252,245,0.94))] p-6 shadow-[0_24px_70px_rgba(216,160,168,0.16)] ring-1 ring-white/80 sm:p-8">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,191,214,0.24),transparent_22%),radial-gradient(circle_at_bottom_right,rgba(255,230,194,0.24),transparent_18%)]"></div>
        <div class="relative space-y-5 text-center lg:text-left">
          <div class="inline-flex rounded-full border border-white bg-white/76 px-3 py-1 text-[0.7rem] uppercase tracking-[0.22em] text-rose-700">Deck unlocked</div>
          <h1 class="font-editorial text-[clamp(2.6rem,5vw,4rem)] font-medium leading-[0.92] text-base-900">Your deck is ready.</h1>
          <p class="max-w-[30rem] text-sm leading-relaxed text-base-700 sm:text-base">
            Your purchase is complete. Open My Deck to choose a starter path, draw one prompt, and begin your first conversation ritual.
          </p>
          <div class="flex flex-wrap justify-center gap-3 lg:justify-start">
            <a href="/my-deck" class="inline-flex h-12 items-center justify-center rounded-full bg-rose-600 px-6 text-sm font-medium text-white shadow-[0_14px_28px_rgba(225,139,166,0.28)] transition hover:bg-rose-700">Open My Deck</a>
            <a href="/" class="inline-flex h-12 items-center justify-center rounded-full border border-white bg-white/80 px-6 text-sm font-medium text-base-900 transition hover:bg-white">Back home</a>
          </div>
        </div>
      </div>

      <div class="overflow-hidden rounded-[2rem] border border-white/80 bg-white/80 p-6 shadow-[0_20px_50px_rgba(216,160,168,0.14)]">
        <Image src={kissScene} alt="" class="mx-auto w-full max-w-[15rem] object-contain" loading="eager" aria-hidden="true" />
        <div class="mt-5 rounded-[1.5rem] bg-blush-50 p-4 ring-1 ring-blush-100">
          <div class="flex items-center gap-3">
            <Image src={hugPose} alt="" class="h-12 w-12 object-contain" loading="lazy" aria-hidden="true" />
            <div>
              <p class="text-[0.68rem] uppercase tracking-[0.18em] text-rose-700">First step</p>
              <p class="mt-1 text-sm text-base-700">Start small. One card and one follow-up is enough for your first session.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
