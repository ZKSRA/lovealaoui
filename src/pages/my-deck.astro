---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { DEFAULT_PRODUCT } from "@/lib/products";
import { hasPurchase } from "@/lib/supabase";
import { hasCheckoutConfig, hasPurchaseValidationConfig } from "@/lib/env";

const currentUser = Astro.locals?.user;

if (!currentUser) {
  return Astro.redirect("/login?next=/my-deck");
}

let purchased = false;
let purchaseValidationConfigured = hasPurchaseValidationConfig();
const checkoutConfigured = hasCheckoutConfig();
let purchaseValidationMessage =
  "Purchase validation is unavailable. Check `PUBLIC_SUPABASE_URL` and `SUPABASE_SERVICE_ROLE_KEY` in Worker settings.";

if (!purchaseValidationConfigured) {
  purchaseValidationMessage =
    "Purchase validation is unavailable because `PUBLIC_SUPABASE_URL` or `SUPABASE_SERVICE_ROLE_KEY` is missing in Worker settings.";
}

if (purchaseValidationConfigured) {
  try {
    purchased = await hasPurchase(currentUser.id, DEFAULT_PRODUCT.slug);
  } catch (error) {
    purchaseValidationConfigured = false;
    purchaseValidationMessage =
      "Purchase validation could not reach Supabase. Check the Worker logs for the exact query error or table permission issue.";
    console.error("[my-deck] purchase validation unavailable", error);
  }
}
---

<BaseLayout>
  <section class="mx-auto max-w-3xl py-12">
    <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-base-100 sm:p-8">
      <h1 class="text-2xl font-semibold">My Deck</h1>
      <p class="mt-2 text-sm text-base-600">Access purchased digital tools from this page.</p>

      {
        !purchaseValidationConfigured ? (
          <div class="mt-6 rounded-2xl border border-amber-300 bg-amber-50 p-4 text-sm text-amber-900">
            {purchaseValidationMessage}
          </div>
        ) : purchased ? (
          <div class="mt-6 rounded-2xl border border-rose-200 bg-rose-50 p-5">
            <h2 class="text-lg font-medium">{DEFAULT_PRODUCT.name}</h2>
            <p class="mt-2 text-sm text-base-700">You're unlocked ✅. This is your protected content area.</p>
            <div class="mt-4 rounded-xl bg-white p-4 text-sm ring-1 ring-base-200">
              Placeholder: replace this block with the real deck viewer/app embed.
            </div>
          </div>
        ) : (
          <div class="mt-6 rounded-2xl border border-base-200 bg-base-50 p-5">
            <h2 class="text-lg font-medium">You haven't purchased this deck yet.</h2>
            <p class="mt-2 text-sm text-base-700">Complete checkout to unlock it instantly in this account.</p>
            {
              !checkoutConfigured && (
                <p class="mt-3 rounded-xl border border-amber-300 bg-amber-50 px-3 py-2 text-sm text-amber-900">
                  Checkout setup is incomplete. Add `STRIPE_SECRET_KEY` and `PUBLIC_SITE_URL` in Worker settings.
                </p>
              )
            }
            <form method="post" action="/api/checkout" class="mt-4">
              <input type="hidden" name="productSlug" value={DEFAULT_PRODUCT.slug} />
              <button type="submit" disabled={!checkoutConfigured} class="inline-flex h-11 items-center justify-center rounded-full bg-base-900 px-6 text-sm font-medium text-white disabled:cursor-not-allowed disabled:opacity-50">Buy {DEFAULT_PRODUCT.name} · $29</button>
            </form>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
