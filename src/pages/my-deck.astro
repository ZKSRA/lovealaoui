---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { DEFAULT_PRODUCT } from "@/lib/products";
import { hasPurchase } from "@/lib/supabase";
import { hasCheckoutConfig, hasPurchaseValidationConfig } from "@/lib/env";
import heroScene from "@/images/mascots/mochi-mates/mochi-mallow-hero-scene.png";

const currentUser = Astro.locals?.user;

if (!currentUser) {
  return Astro.redirect("/login?next=/my-deck");
}

let purchased = false;
let purchaseValidationConfigured = hasPurchaseValidationConfig();
const checkoutConfigured = hasCheckoutConfig();
let purchaseValidationMessage =
  "We are having trouble checking deck access right now. Please try again shortly or contact support if this continues.";

if (!purchaseValidationConfigured) {
  purchaseValidationMessage =
    "Deck access cannot be confirmed in this environment yet. If you already purchased, contact support with the email tied to your account.";
}

if (purchaseValidationConfigured) {
  try {
    purchased = await hasPurchase(currentUser.id, DEFAULT_PRODUCT.slug);
  } catch (error) {
    purchaseValidationConfigured = false;
    purchaseValidationMessage =
      "Purchase validation could not reach Supabase. Check the Worker logs for the exact query error or table permission issue.";
    console.error("[my-deck] purchase validation unavailable", error);
  }
}

const ritualPaths = [
  {
    title: "Quick reconnect",
    detail: "One warm question when the evening needs an easier beginning.",
    time: "5 min",
  },
  {
    title: "Date-night spark",
    detail: "A softer way to move past small talk and back into each other.",
    time: "10 min",
  },
  {
    title: "Weekly check-in",
    detail: "A calm reset for what felt good, what felt hard, and what comes next.",
    time: "15 min",
  },
];

const starterPrompts = [
  {
    eyebrow: "Gentle start",
    title: "What helped you feel most cared for by me this week?",
    detail: "Answer in one sentence each, then ask one follow-up.",
  },
  {
    eyebrow: "Reset",
    title: "What are we carrying into tonight that we don't want to keep carrying?",
    detail: "Name it softly, then choose one tiny way to make the week feel lighter.",
  },
  {
    eyebrow: "Next week",
    title: "What would make next week feel a little more us?",
    detail: "End by choosing one small thing to protect together.",
  },
];

const progressStats = purchased
  ? [
      { label: "Status", value: "Unlocked" },
      { label: "Prompts", value: "120" },
      { label: "Tonight", value: "Quick reconnect" },
    ]
  : [
      { label: "Status", value: "Preview" },
      { label: "Price", value: "$29 once" },
      { label: "Prompts", value: "120" },
    ];

const featuredPrompt = starterPrompts[0];

const title = purchased ? "My Deck | Love Alaoui" : "Preview My Deck | Love Alaoui";
const description = purchased
  ? "Open your Better Conversations Deck, choose a starter path, and begin a private Love Alaoui conversation ritual."
  : "Preview My Deck and unlock The Better Conversations Deck for warmer date nights, easier check-ins, and private account access.";
---

<BaseLayout title={title} description={description} canonicalPath="/my-deck" robots="noindex, follow">
  <section class="mx-auto max-w-5xl space-y-6 py-8 sm:py-10">
    {
      !purchaseValidationConfigured && (
        <div class="rounded-2xl border border-amber-300 bg-amber-50 p-4 text-sm text-amber-900">
          {purchaseValidationMessage}
        </div>
      )
    }

    <div class="overflow-hidden rounded-[2rem] bg-white/88 shadow-[0_24px_70px_rgba(216,160,168,0.13)] ring-1 ring-white/90">
      <div class="grid gap-0 lg:grid-cols-[minmax(0,1fr)_minmax(20rem,.78fr)]">
        <div class="space-y-5 px-6 py-7 sm:px-8 lg:px-10 lg:py-10">
          <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">{purchased ? "Unlocked" : "Preview"}</p>
          <h1 class="font-editorial max-w-[12ch] text-[clamp(2.45rem,5vw,4.2rem)] font-medium leading-[0.94] text-base-900">
            The Better Conversations Deck.
          </h1>
          <p class="max-w-xl text-sm leading-relaxed text-base-700 sm:text-base">
            {
              purchased
                ? "Choose a path, draw one prompt, and make tonight's conversation easier to begin."
                : "Unlock 120 guided prompts for date nights, weekly check-ins, and the moments that need a softer start."
            }
          </p>

          <div class="flex flex-wrap gap-3">
            {
              purchased ? (
                <a href="#start-tonight" class="inline-flex h-11 items-center justify-center rounded-full bg-rose-600 px-6 text-sm font-medium text-white shadow-[0_14px_28px_rgba(225,139,166,0.28)] transition hover:bg-rose-700">
                  Start tonight's ritual
                </a>
              ) : (
                <form method="post" action="/api/checkout">
                  <input type="hidden" name="productSlug" value={DEFAULT_PRODUCT.slug} />
                  <button type="submit" disabled={!checkoutConfigured} class="inline-flex h-11 items-center justify-center rounded-full bg-rose-600 px-6 text-sm font-medium text-white shadow-[0_14px_28px_rgba(225,139,166,0.28)] disabled:cursor-not-allowed disabled:opacity-50">
                    Unlock {DEFAULT_PRODUCT.name} · $29
                  </button>
                </form>
              )
            }
            <a href="#starter-prompts" class="inline-flex h-11 items-center justify-center rounded-full border border-white bg-white/84 px-6 text-sm font-medium text-base-900 transition hover:bg-white">
              Preview prompts
            </a>
          </div>

          <div class="grid grid-cols-3 gap-2 pt-2 sm:gap-3">
            {progressStats.map((stat) => (
              <article class="rounded-[1.25rem] bg-base-50 px-3 py-3 ring-1 ring-base-100 sm:px-4">
                <p class="text-[0.65rem] uppercase tracking-[0.16em] text-base-500">{stat.label}</p>
                <p class="mt-1 text-sm font-medium text-base-900 sm:text-base">{stat.value}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="bg-[linear-gradient(180deg,rgba(255,250,247,0.96),rgba(246,239,234,0.82))] px-6 py-6 sm:px-8 lg:px-8 lg:py-10">
          <div class="relative h-full rounded-[1.75rem] bg-white/82 p-5 ring-1 ring-white shadow-[0_18px_52px_rgba(104,74,74,0.10)]">
            <p class="text-xs font-medium uppercase tracking-[0.2em] text-rose-700">Tonight's card</p>
            <h2 class="mt-3 text-xl font-semibold leading-tight text-base-900">{featuredPrompt.title}</h2>
            <p class="mt-4 max-w-sm text-sm leading-relaxed text-base-700">{featuredPrompt.detail}</p>
            <div class="mt-6 rounded-[1.25rem] bg-base-50 p-4 ring-1 ring-base-100">
              <p class="text-xs uppercase tracking-[0.18em] text-base-500">How to use it</p>
              <p class="mt-2 text-sm leading-relaxed text-base-800">Answer, ask one follow-up, then choose one small thing to carry into the week.</p>
            </div>
            <Image src={heroScene} alt="" class="pointer-events-none absolute bottom-4 right-4 hidden w-20 object-contain opacity-80 drop-shadow-[0_12px_22px_rgba(71,46,46,0.10)] sm:block" loading="lazy" aria-hidden="true" />
          </div>
        </div>
      </div>
    </div>

    <section id="start-tonight" class="rounded-[2rem] bg-white/86 p-6 shadow-[0_20px_60px_rgba(216,160,168,0.10)] ring-1 ring-white sm:p-8">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
        <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">Start tonight</p>
        <h2 class="mt-2 text-2xl font-semibold text-base-900">
          Choose the kind of closeness you need.
        </h2>
        <p class="mt-3 text-sm leading-relaxed text-base-700">
          Pick one path. Let one good question be enough.
        </p>
        </div>
        {!purchased && <p class="max-w-xs text-sm leading-relaxed text-base-600">Unlock the deck to use every path and prompt from your private account.</p>}
      </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-3">
          {ritualPaths.map((path) => (
            <article class="rounded-[1.5rem] bg-white p-4 ring-1 ring-base-100 shadow-sm">
              <p class="text-xs uppercase tracking-[0.16em] text-rose-700">{path.time}</p>
              <h3 class="mt-2 text-base font-medium text-base-900">{path.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-base-600">{path.detail}</p>
            </article>
          ))}
        </div>
    </section>

    <section id="starter-prompts" class="rounded-[2rem] bg-white/86 p-6 shadow-[0_20px_60px_rgba(216,160,168,0.10)] ring-1 ring-white sm:p-8">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">Starter prompts</p>
          <h2 class="mt-2 text-2xl font-semibold text-base-900">A few ways in.</h2>
        </div>
        <p class="max-w-sm text-sm leading-relaxed text-base-600">Each prompt is designed to start lightly, then leave you with one small next step.</p>
      </div>

      <div class="mt-5 grid gap-3 lg:grid-cols-3">
        {starterPrompts.map((prompt) => (
          <article class="rounded-[1.5rem] bg-white p-5 ring-1 ring-base-100 shadow-sm">
            <p class="text-xs uppercase tracking-[0.2em] text-rose-700">{prompt.eyebrow}</p>
            <h3 class="mt-3 text-base font-medium text-base-900">{prompt.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-base-600">{prompt.detail}</p>
          </article>
        ))}
      </div>
    </section>
  </section>
</BaseLayout>
