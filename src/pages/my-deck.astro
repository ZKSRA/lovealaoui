---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { DEFAULT_PRODUCT } from "@/lib/products";
import { hasPurchase } from "@/lib/supabase";
import { hasCheckoutConfig, hasPurchaseValidationConfig } from "@/lib/env";
import heroScene from "@/images/mascots/mochi-mates/mochi-mallow-hero-scene.png";
import gazeScene from "@/images/mascots/mochi-mates/mochi-mallow-gaze.png";
import listeningMochi from "@/images/mascots/mochi-mates/mochi-listening.png";
import mallowHeart from "@/images/mascots/mochi-mates/mallow-heart.png";

const currentUser = Astro.locals?.user;

if (!currentUser) {
  return Astro.redirect("/login?next=/my-deck");
}

let purchased = false;
let purchaseValidationConfigured = hasPurchaseValidationConfig();
const checkoutConfigured = hasCheckoutConfig();
let purchaseValidationMessage =
  "We are having trouble checking deck access right now. Please try again shortly or contact support if this continues.";

if (!purchaseValidationConfigured) {
  purchaseValidationMessage =
    "Deck access cannot be confirmed in this environment yet. If you already purchased, contact support with the email tied to your account.";
}

if (purchaseValidationConfigured) {
  try {
    purchased = await hasPurchase(currentUser.id, DEFAULT_PRODUCT.slug);
  } catch (error) {
    purchaseValidationConfigured = false;
    purchaseValidationMessage =
      "Purchase validation could not reach Supabase. Check the Worker logs for the exact query error or table permission issue.";
    console.error("[my-deck] purchase validation unavailable", error);
  }
}

const ritualPaths = [
  {
    title: "Quick reconnect",
    detail: "A 5-minute reset for nights when you want warmth without pressure.",
    time: "5 min",
  },
  {
    title: "Date-night spark",
    detail: "Playful prompts for nights when you want closeness, chemistry, and a little softness.",
    time: "10 min",
  },
  {
    title: "Weekly check-in",
    detail: "A calmer ritual for reflecting, naming needs, and ending with one tiny promise.",
    time: "15 min",
  },
];

const starterPrompts = [
  {
    eyebrow: "Tonight's gentle start",
    title: "What helped you feel most cared for by me this week?",
    detail: "Answer in one sentence each, then ask one follow-up.",
  },
  {
    eyebrow: "Reset after a long week",
    title: "What are we carrying into tonight that we don't want to keep carrying?",
    detail: "Name it softly, then choose one tiny way to make the week feel lighter.",
  },
  {
    eyebrow: "Future ritual",
    title: "What would make next week feel a little more us?",
    detail: "End by choosing one small thing to protect together.",
  },
];

const mascotNotes = [
  { title: "Mochi's pick", detail: "Start gently and let one honest answer be enough.", image: listeningMochi },
  { title: "Mallow's pick", detail: "Add a tiny flirt or a silly promise so the ritual stays light.", image: mallowHeart },
];

const progressStats = purchased
  ? [
      { label: "Ritual status", value: "Unlocked" },
      { label: "Prompts inside", value: "120" },
      { label: "Suggested tonight", value: "Quick reconnect" },
    ]
  : [
      { label: "Ritual status", value: "Preview" },
      { label: "Unlocks instantly", value: DEFAULT_PRODUCT.name },
      { label: "Prompts inside", value: "120" },
    ];

const title = purchased ? "My Deck | Love Alaoui" : "Preview My Deck | Love Alaoui";
const description = purchased
  ? "Open your Better Conversations Deck, choose a starter path, and begin a private Love Alaoui conversation ritual."
  : "Preview My Deck and unlock The Better Conversations Deck for warmer date nights, easier check-ins, and private account access.";
---

<BaseLayout title={title} description={description} canonicalPath="/my-deck" robots="noindex, follow">
  <section class="mx-auto max-w-5xl space-y-6 py-12">
    {
      !purchaseValidationConfigured && (
        <div class="rounded-2xl border border-amber-300 bg-amber-50 p-4 text-sm text-amber-900">
          {purchaseValidationMessage}
        </div>
      )
    }

    <div class="overflow-hidden rounded-[2rem] bg-[linear-gradient(180deg,rgba(255,250,247,0.98),rgba(255,244,247,0.94))] shadow-[0_24px_70px_rgba(216,160,168,0.16)] ring-1 ring-white/90">
      <div class="grid gap-0 lg:grid-cols-[1.05fr_.95fr]">
        <div class="space-y-5 px-6 py-7 sm:px-8 sm:py-8 lg:px-10 lg:py-10">
          <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">My Deck</p>
          <h1 class="font-editorial max-w-[11ch] text-[clamp(2.45rem,5vw,4rem)] font-medium leading-[0.94] text-base-900">
            {purchased ? "Your Better Conversations Deck is open." : "Preview your Better Conversations Deck."}
          </h1>
          <p class="max-w-2xl text-sm leading-relaxed text-base-700">
            {
              purchased
                ? `Your account is ready for ${DEFAULT_PRODUCT.name}. Pick a path, draw one prompt, and make tonight's check-in easy to begin.`
                : `This is where ${DEFAULT_PRODUCT.name} lives after purchase. Unlock 120 prompts, starter rituals, and private account access you can return to any night.`
            }
          </p>

          <div class="flex flex-wrap gap-3">
            {
              purchased ? (
                <a href="#start-tonight" class="inline-flex h-11 items-center justify-center rounded-full bg-rose-600 px-6 text-sm font-medium text-white shadow-[0_14px_28px_rgba(225,139,166,0.28)] transition hover:bg-rose-700">
                  Start tonight's ritual
                </a>
              ) : (
                <form method="post" action="/api/checkout">
                  <input type="hidden" name="productSlug" value={DEFAULT_PRODUCT.slug} />
                  <button type="submit" disabled={!checkoutConfigured} class="inline-flex h-11 items-center justify-center rounded-full bg-rose-600 px-6 text-sm font-medium text-white shadow-[0_14px_28px_rgba(225,139,166,0.28)] disabled:cursor-not-allowed disabled:opacity-50">
                    Unlock {DEFAULT_PRODUCT.name} · $29
                  </button>
                </form>
              )
            }
            <a href="#starter-prompts" class="inline-flex h-11 items-center justify-center rounded-full border border-white bg-white/84 px-6 text-sm font-medium text-base-900 transition hover:bg-white">
              See starter prompts
            </a>
          </div>

          <div class="grid gap-3 sm:grid-cols-3">
            {progressStats.map((stat) => (
              <article class="rounded-2xl bg-white/80 px-4 py-4 ring-1 ring-white shadow-[0_10px_24px_rgba(225,197,204,0.10)]">
                <p class="text-xs uppercase tracking-[0.18em] text-base-500">{stat.label}</p>
                <p class="mt-2 text-lg font-medium text-base-900">{stat.value}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="bg-[radial-gradient(circle_at_top,_rgba(255,237,238,.72),_rgba(255,248,244,.84)_38%,_rgba(250,247,244,.92)_100%)] px-6 py-7 sm:px-8 sm:py-8 lg:px-8 lg:py-10">
          <div class="relative mx-auto flex h-full min-h-[18rem] max-w-[22rem] items-center justify-center rounded-[2rem] border border-white/80 bg-white/68 p-6 shadow-[0_20px_60px_rgba(104,74,74,0.10)]">
            <Image src={heroScene} alt="" class="w-[72%] max-w-[16rem] object-contain drop-shadow-[0_20px_30px_rgba(71,46,46,0.12)]" aria-hidden="true" />
            <div class="absolute bottom-5 left-5 max-w-[12rem] rounded-[1.35rem] bg-white/92 p-3 shadow-lg ring-1 ring-rose-100">
              <p class="text-[0.65rem] font-medium uppercase tracking-[0.22em] text-rose-700">A little nudge</p>
              <p class="mt-2 text-sm leading-relaxed text-base-800">
                {purchased ? "Start smaller than you think. One good prompt is enough to change the mood." : "Your private deck unlocks instantly after checkout."}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <section id="start-tonight" class="grid gap-4 lg:grid-cols-[1.05fr_.95fr]">
      <div class="rounded-[2rem] bg-white/86 p-6 shadow-[0_20px_60px_rgba(216,160,168,0.12)] ring-1 ring-white sm:p-8">
        <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">Start tonight</p>
        <h2 class="mt-2 text-2xl font-semibold text-base-900">
          {purchased ? "Choose the kind of closeness you need." : "Preview the paths waiting inside."}
        </h2>
        <p class="mt-3 text-sm leading-relaxed text-base-700">
          {purchased ? "You do not need a perfect evening. Pick one path, answer one prompt, and let that be enough to start." : "Every deck begins with a few easy entry points so you never have to wonder how to begin."}
        </p>

        <div class="mt-5 grid gap-3 sm:grid-cols-3">
          {ritualPaths.map((path) => (
            <article class="rounded-3xl bg-gradient-to-b from-white to-rose-50 p-4 ring-1 ring-rose-100 shadow-[0_10px_24px_rgba(225,197,204,0.10)]">
              <p class="text-xs uppercase tracking-[0.16em] text-rose-700">{path.time}</p>
              <h3 class="mt-2 text-base font-medium text-base-900">{path.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-base-600">{path.detail}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="rounded-[2rem] bg-[linear-gradient(180deg,rgba(246,251,248,0.96),rgba(255,247,246,0.92))] p-6 ring-1 ring-white sm:p-8">
        <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">How this works</p>
        <h2 class="mt-2 text-2xl font-semibold text-base-900">A simple ritual in three steps.</h2>
        <ol class="mt-5 space-y-4 text-sm text-base-700">
          <li>
            <span class="font-medium text-base-900">1. Pick your mood.</span> Choose whether you need a quick reconnect, a date-night spark, or a deeper check-in.
          </li>
          <li>
            <span class="font-medium text-base-900">2. Draw one prompt.</span> Read it out loud, answer honestly, then ask one soft follow-up.
          </li>
          <li>
            <span class="font-medium text-base-900">3. End with one tiny promise.</span> Keep it small enough that it actually changes the next few days.
          </li>
        </ol>
      </div>
    </section>

    <section id="starter-prompts" class="rounded-[2rem] bg-white/86 p-6 shadow-[0_20px_60px_rgba(216,160,168,0.12)] ring-1 ring-white sm:p-8">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">Starter prompts</p>
          <h2 class="mt-2 text-2xl font-semibold text-base-900">Begin with something gentle and real.</h2>
        </div>
        {!purchased && <p class="max-w-sm text-sm text-base-600">Unlock the deck to turn these previews into a ritual home you can return to any night.</p>}
      </div>

      <div class="mt-5 grid gap-3 lg:grid-cols-3">
        {starterPrompts.map((prompt) => (
          <article class="rounded-3xl bg-gradient-to-b from-white to-rose-50 p-5 ring-1 ring-rose-100">
            <p class="text-xs uppercase tracking-[0.2em] text-rose-700">{prompt.eyebrow}</p>
            <h3 class="mt-3 text-base font-medium text-base-900">{prompt.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-base-600">{prompt.detail}</p>
          </article>
        ))}
      </div>

      {!purchased && <div class="mt-6 grid gap-3 sm:grid-cols-2">
        {mascotNotes.map((note) => (
          <article class="rounded-[1.5rem] border border-white bg-[#fffaf8] p-4 shadow-[0_10px_24px_rgba(225,197,204,0.10)]">
            <div class="flex items-center gap-3">
              <Image src={note.image} alt="" class="h-12 w-12 object-contain" loading="lazy" aria-hidden="true" />
              <div>
                <p class="text-xs uppercase tracking-[0.18em] text-rose-700">{note.title}</p>
                <p class="mt-1 text-sm text-base-700">{note.detail}</p>
              </div>
            </div>
          </article>
        ))}
      </div>}
    </section>

    <section class="grid gap-4 lg:grid-cols-[1.02fr_.98fr]">
      <div class="rounded-[2rem] bg-[linear-gradient(180deg,rgba(245,251,248,0.96),rgba(255,247,246,0.92))] p-6 ring-1 ring-white sm:p-8">
        <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">Deck overview</p>
        <h2 class="mt-2 text-2xl font-semibold text-base-900">{DEFAULT_PRODUCT.name}</h2>
        <p class="mt-3 text-sm leading-relaxed text-base-700">{DEFAULT_PRODUCT.description}</p>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          <div class="rounded-2xl bg-white px-4 py-4 ring-1 ring-base-100">
            <p class="text-xs uppercase tracking-[0.16em] text-base-500">Best for</p>
            <p class="mt-2 text-sm font-medium text-base-900">Date nights, weekly check-ins, and reset evenings</p>
          </div>
          <div class="rounded-2xl bg-white px-4 py-4 ring-1 ring-base-100">
            <p class="text-xs uppercase tracking-[0.16em] text-base-500">Feel</p>
            <p class="mt-2 text-sm font-medium text-base-900">Playful, calm, reflective, and easy to revisit</p>
          </div>
        </div>
      </div>

      <div class="rounded-[2rem] bg-white/86 p-6 shadow-[0_20px_60px_rgba(216,160,168,0.12)] ring-1 ring-white sm:p-8">
        <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">A note for tonight</p>
        <h2 class="mt-2 text-2xl font-semibold text-base-900">Two minutes still counts.</h2>
        <p class="mt-3 text-sm leading-relaxed text-base-700">
          The goal is not to do this perfectly. The goal is to create a tiny opening for honesty, care, and closeness more often than you would without it.
        </p>
        <div class="mt-5 flex items-center gap-4 rounded-3xl bg-gradient-to-r from-rose-50 to-amber-50 p-4 ring-1 ring-rose-100">
          <Image src={gazeScene} alt="" class="h-16 w-16 object-contain" loading="lazy" aria-hidden="true" />
          <p class="text-sm leading-relaxed text-base-800">
            Start smaller than you think. If one card makes you smile and talk for five extra minutes, the ritual worked.
          </p>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
