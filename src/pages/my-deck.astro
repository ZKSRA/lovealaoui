---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="mx-auto max-w-md py-14">
    <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-base-100 sm:p-8">
      <h1 class="text-2xl font-semibold">Deck access coming soon</h1>
      <p class="mt-2 text-sm leading-relaxed text-base-600">
        Digital deck delivery and account unlock are in progress. The launch storefront remains available now.
      </p>
      <a href="/#featured-product" class="mt-6 inline-flex h-11 items-center justify-center rounded-full bg-base-900 px-5 text-sm font-medium text-white">See featured deck</a>
    </div>
  </section>
</BaseLayout>
