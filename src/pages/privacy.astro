---
import BaseLayout from "@/layouts/BaseLayout.astro";

const title = "Privacy Policy for Love Alaoui & The Better Conversations Deck";
const description = "Read how Love Alaoui handles account details, checkout information, support requests, and access to The Better Conversations Deck.";
---

<BaseLayout title={title} description={description} canonicalPath="/privacy">
  <section class="mx-auto max-w-3xl py-12">
    <div class="rounded-[2rem] bg-white/88 p-6 shadow-[0_20px_60px_rgba(216,160,168,0.14)] ring-1 ring-white sm:p-8">
      <p class="text-xs uppercase tracking-[0.22em] text-rose-700">Privacy</p>
      <h1 class="font-editorial mt-2 text-[clamp(2.2rem,4vw,3.4rem)] font-medium leading-[0.94] text-base-900">Privacy Policy</h1>
      <div class="mt-6 space-y-5 text-sm leading-relaxed text-base-700">
        <p>Love Alaoui collects only the information needed to create your account, deliver access to your purchases, and support the relationship tools you choose to use.</p>
        <p>For account access, we may store your email address and authentication details through our sign-in provider. For checkout, payment processing is handled by Stripe, and we do not store your full payment card details on our servers.</p>
        <p>We use product and account data to deliver access to The Better Conversations Deck, confirm purchases, and maintain the ritual experience connected to your account.</p>
        <p>If you contact us directly, we may keep the information you share so we can respond and support your request.</p>
        <p>For privacy questions, contact us through the contact page and include the email tied to your account so we can help more quickly.</p>
        <p>We aim to keep the amount of personal data small and directly connected to the service you are using. The information we keep should help with access, account support, purchase confirmation, and ongoing delivery of your digital product experience.</p>
        <p>If our tools or providers change over time, the purpose stays the same: support secure access to your purchase, make account recovery possible, and respond clearly when you ask for help.</p>
        <p>If you would like to update or remove information connected to your account, contact us and include the account email so we can review the request with the right context.</p>
        <p>This policy is meant to be clear and practical. We only want to keep what helps the product function, what helps purchases connect to the right account, and what helps support requests get answered accurately and kindly.</p>
      </div>
    </div>
  </section>
</BaseLayout>
