---
export const prerender = false;

import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { DEFAULT_PRODUCT } from "@/lib/products";
import { PREVIEW_DECK_CARDS } from "@/lib/deck-cards";
import logoInline from "@/images/branding/love-alaoui-logo-inline.png";
import heroScene from "@/images/mascots/mochi-mates/mochi-mallow-hero-scene.png";
import mochiShy from "@/images/mascots/mochi-mates/mochi-shy-smile.png";
import mochiListening from "@/images/mascots/mochi-mates/mochi-listening.png";
import mallowReady from "@/images/mascots/mochi-mates/mallow-ready.png";
import mallowHeart from "@/images/mascots/mochi-mates/mallow-heart.png";

const featuredProduct = {
  name: DEFAULT_PRODUCT.name,
  price: "$29",
};

const trustDetails = [
  "120 prompts",
  "$29 once",
  "Private account access",
  "Secure Stripe checkout",
];

const useCases = [
  {
    title: "Check in",
    desc: "Name what felt good, what felt hard, and what you need next.",
  },
  {
    title: "Reconnect",
    desc: "Restart gently after a busy week, a long day, or distance.",
  },
  {
    title: "Go deeper",
    desc: "Move beyond default conversation without making the night heavy.",
  },
];

const characterArt = {
  Mochi: mochiShy.src,
  Mallow: mallowReady.src,
  "Mochi & Mallow": heroScene.src,
};

const characterAltArt = {
  Mochi: mochiListening.src,
  Mallow: mallowHeart.src,
  "Mochi & Mallow": heroScene.src,
};

const previewDeckCards = PREVIEW_DECK_CARDS.map((card) => ({
  ...card,
  characterImage: characterArt[card.character],
  characterAltImage: characterAltArt[card.character],
}));

const testimonials = [
  {
    quote: "It gives us a better starting point than small talk. We actually use it instead of just meaning to reconnect.",
    author: "A + J · serious dating",
  },
];

const faqs = [
  {
    q: "Is this a physical product?",
    a: "No. Love Alaoui is a digital experience you unlock online and revisit whenever you want.",
  },
  {
    q: "How do we access it?",
    a: "You sign in to your account and open your private deck inside My Deck after purchase.",
  },
  {
    q: "Can we use it on our phones?",
    a: "Yes. The experience is designed mobile-first so it feels natural on the sofa, at dinner, or from long distance.",
  },
  {
    q: "Who is it for?",
    a: "Serious dating, engaged, married, and long-distance couples who want better conversations without pressure or therapy-speak.",
  },
  {
    q: "When should we use it?",
    a: "Date nights, weekly check-ins, after a tense week, or any evening when you want to feel more intentional together.",
  },
];

const title = "Love Alaoui | The Better Conversations Deck for Couples";
const description = "A one-time-purchase digital conversation deck for couples who want warmer date nights, easier check-ins, and more meaningful conversations without awkward starts.";
---

<BaseLayout title={title} description={description} canonicalPath="/">
  <div class="space-y-12 py-6 pb-24 sm:space-y-14 sm:py-8 lg:space-y-20 lg:py-10">
    <section class="relative overflow-hidden rounded-[2rem] bg-[linear-gradient(180deg,rgba(255,250,247,0.95),rgba(255,244,247,0.92))] shadow-[0_28px_90px_rgba(216,160,168,0.16)] ring-1 ring-white/80" aria-labelledby="hero-title">
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_22%,rgba(255,189,215,0.24),transparent_18%),radial-gradient(circle_at_82%_16%,rgba(219,235,216,0.22),transparent_16%),radial-gradient(circle_at_72%_78%,rgba(255,228,192,0.18),transparent_20%)]"></div>
      <div class="grid gap-8 px-5 py-8 md:grid-cols-[minmax(0,1fr)_minmax(18rem,.82fr)] md:items-center md:px-8 md:py-10 lg:px-10 lg:py-12">
        <div class="space-y-6">
          <p class="text-xs font-medium uppercase tracking-[0.24em] text-rose-700">120-prompt digital deck</p>
          <h1 id="hero-title" class="font-editorial max-w-[9ch] text-[clamp(3.15rem,7vw,5.4rem)] font-medium leading-[0.92] text-base-900">
            Better conversations for couples.
          </h1>
          <p class="max-w-[28rem] text-base leading-relaxed text-base-700">
            Date nights, check-ins, and the moments that need a softer start.
          </p>

          <div class="flex flex-wrap gap-3">
            <a href="/signup?next=/my-deck" class="inline-flex h-12 items-center justify-center rounded-full bg-rose-600 px-6 text-sm font-medium text-white shadow-[0_14px_30px_rgba(225,139,166,0.34)] transition hover:bg-rose-700">
              Sign up & unlock
            </a>
          </div>

        </div>

        <div class="relative mx-auto hidden w-full max-w-[27rem] md:block">
          <div class="absolute inset-x-14 top-10 h-[64%] rounded-full bg-rose-200/35 blur-3xl"></div>
          <div class="relative ml-auto w-[82%] rounded-[2rem] bg-white/58 px-7 py-8 ring-1 ring-white/90 shadow-[0_24px_64px_rgba(216,160,168,0.16)] backdrop-blur">
            <Image src={heroScene} alt="" class="mx-auto w-full max-w-[14rem] object-contain drop-shadow-[0_14px_26px_rgba(215,154,167,0.18)]" loading="eager" aria-hidden="true" />
          </div>
        </div>
      </div>
    </section>

    <section id="featured-product" class="rounded-[2rem] bg-white/80 px-5 py-5 shadow-[0_18px_50px_rgba(216,160,168,0.10)] ring-1 ring-white sm:px-7" aria-label="Product facts">
        <div class="grid grid-cols-2 gap-3 text-center text-sm font-medium text-base-800 md:flex md:flex-wrap md:items-center md:justify-center md:gap-x-6 md:gap-y-2">
          {trustDetails.map((detail) => (
            <span>{detail}</span>
          ))}
        </div>
    </section>

    <section id="how-it-works" class="rounded-[2rem] bg-white px-5 py-9 shadow-sm ring-1 ring-base-100 sm:px-7 lg:px-10 lg:py-12" aria-labelledby="how-heading">
      <div class="mx-auto max-w-4xl text-center">
        <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">How it fits</p>
        <h2 id="how-heading" class="font-editorial mx-auto mt-3 max-w-3xl text-[clamp(2rem,4.5vw,3.2rem)] font-medium leading-[0.98] text-base-900">
          Use it when the moment needs a better start.
        </h2>
      </div>

      <div class="mx-auto mt-8 grid max-w-5xl gap-5 md:grid-cols-3">
        {useCases.map((item) => (
          <article class="border-t border-base-200 pt-4 text-left md:text-center">
            <h3 class="text-lg font-semibold text-base-900">{item.title}</h3>
            <p class="mx-auto mt-2 max-w-xs text-sm leading-relaxed text-base-700">{item.desc}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="preview" class="overflow-hidden rounded-[2rem] bg-[linear-gradient(180deg,rgba(255,250,247,0.96),rgba(255,244,247,0.90))] p-5 shadow-[0_24px_70px_rgba(216,160,168,0.12)] ring-1 ring-white/90 sm:p-5" aria-labelledby="preview-heading" data-landing-deck>
      <div class="grid gap-5 md:grid-cols-[minmax(0,.72fr)_minmax(18rem,.72fr)] md:items-center">
        <div class="relative z-10">
          <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">Try the deck</p>
          <h2 id="preview-heading" class="font-editorial mt-3 max-w-[11ch] text-[clamp(2rem,4.2vw,3rem)] font-medium leading-[0.98] text-base-900">
            Slide through a few test cards.
          </h2>
          <p class="mt-4 max-w-lg text-sm leading-relaxed text-base-700 sm:text-base">
            Every card gives you a question, a follow-up, and one tiny next step. Unlock once to open all 120.
          </p>
          <a href="/signup?next=/my-deck" class="mt-5 inline-flex h-11 items-center justify-center rounded-full bg-base-900 px-6 text-sm font-medium text-white transition hover:bg-base-800">
            Unlock all 120 · {featuredProduct.price}
          </a>
        </div>

        <div class="landing-deck-stage" aria-live="polite">
          <div class="landing-card-back landing-card-back-one"></div>
          <div class="landing-card-back landing-card-back-two"></div>
          <article class="landing-card" data-landing-card-shell>
            <div class="landing-card-brand">
              <img src={logoInline.src} alt="Love Alaoui" class="landing-card-logo" />
              <span data-landing-count>1 / {previewDeckCards.length}</span>
            </div>
            <img src={previewDeckCards[0].characterImage} alt="" class="landing-card-character" data-landing-character aria-hidden="true" />
            <p class="landing-card-mode" data-landing-mode>{previewDeckCards[0].mode}</p>
            <h3 class="landing-card-question" data-landing-question>{previewDeckCards[0].question}</h3>
            <div class="landing-card-note">
              <p>Follow-up</p>
              <span data-landing-follow>{previewDeckCards[0].followUp}</span>
            </div>
          </article>
          <div class="landing-deck-toolbar" aria-label="Test card controls">
            <button type="button" class="landing-deck-nav" data-landing-prev aria-label="Previous test card">Prev</button>
            <button type="button" class="landing-deck-nav landing-deck-nav-next" data-landing-next aria-label="Next test card">Next</button>
          </div>
        </div>
      </div>
    </section>

    <section class="rounded-[2rem] bg-white p-6 ring-1 ring-base-100 sm:p-8" aria-labelledby="social-proof-heading">
      <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">Early feedback</p>
      {testimonials.map((item) => (
        <blockquote class="mt-3 max-w-3xl">
          <p id="social-proof-heading" class="font-editorial text-[clamp(1.8rem,4vw,2.7rem)] leading-tight text-base-900">“{item.quote}”</p>
          <footer class="mt-4 text-xs uppercase tracking-[0.16em] text-base-500">{item.author}</footer>
        </blockquote>
      ))}
    </section>

    <section id="faq" class="space-y-4" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-[clamp(1.45rem,3.5vw,2rem)] font-semibold text-base-900">FAQ</h2>
      <div class="space-y-2">
        {faqs.map((item) => (
          <details class="rounded-2xl bg-white p-4 shadow-sm ring-1 ring-base-100">
            <summary class="cursor-pointer list-none pr-6 text-sm font-medium text-base-900">{item.q}</summary>
            <p class="mt-2 text-sm leading-relaxed text-base-700">{item.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section id="final-cta" class="rounded-[2rem] bg-base-900 px-5 py-10 text-center text-white sm:px-7 lg:px-10" aria-labelledby="final-cta-heading">
      <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-200">Ready to feel closer this week?</p>
      <h2 id="final-cta-heading" class="mx-auto mt-3 max-w-2xl text-[clamp(1.45rem,4vw,2.25rem)] font-semibold leading-tight">
        Start with one deck and make closeness easier to begin again.
      </h2>
      <p class="mx-auto mt-3 max-w-2xl text-sm text-rose-100">
        Unlock {featuredProduct.name} once and give yourselves a private conversation ritual you can return to whenever the week needs more care.
      </p>
      <a
        href="/signup?next=/my-deck"
        class="mt-5 inline-flex h-11 items-center justify-center rounded-full bg-white px-6 text-sm font-medium text-base-900 transition hover:bg-base-100"
      >Sign up & unlock · {featuredProduct.price}</a>
    </section>
  </div>

  <div class="fixed inset-x-0 bottom-0 z-20 border-t border-base-200 bg-white/95 p-3 shadow-[0_-8px_24px_rgba(45,30,30,.06)] backdrop-blur sm:hidden">
    <a
      href="/signup?next=/my-deck"
      class="inline-flex h-11 w-full items-center justify-center rounded-full bg-base-900 px-6 text-sm font-medium text-white"
    >Sign up & unlock · {featuredProduct.price}</a>
  </div>

  <script is:inline define:vars={{ previewDeckCards }}>
    const root = document.querySelector("[data-landing-deck]");
    const cards = previewDeckCards;

    if (root && cards.length > 0) {
      let currentIndex = 0;
      const shell = root.querySelector("[data-landing-card-shell]");
      const count = root.querySelector("[data-landing-count]");
      const character = root.querySelector("[data-landing-character]");
      const mode = root.querySelector("[data-landing-mode]");
      const question = root.querySelector("[data-landing-question]");
      const follow = root.querySelector("[data-landing-follow]");
      const prev = root.querySelector("[data-landing-prev]");
      const next = root.querySelector("[data-landing-next]");

      const render = (nextIndex) => {
        currentIndex = (nextIndex + cards.length) % cards.length;
        const card = cards[currentIndex];
        shell?.classList.remove("is-sliding");
        requestAnimationFrame(() => shell?.classList.add("is-sliding"));

        if (count) count.textContent = `${currentIndex + 1} / ${cards.length}`;
        if (character) character.setAttribute("src", currentIndex % 2 === 0 ? card.characterImage : card.characterAltImage);
        if (mode) mode.textContent = card.mode;
        if (question) question.textContent = card.question;
        if (follow) follow.textContent = card.followUp;
      };

      prev?.addEventListener("click", () => render(currentIndex - 1));
      next?.addEventListener("click", () => render(currentIndex + 1));
    }
  </script>

  <style>
    .landing-deck-stage {
      position: relative;
      overflow: hidden;
      min-height: 29rem;
      display: grid;
      align-content: center;
      justify-items: center;
      padding-top: 1.6rem;
      isolation: isolate;
    }

    .landing-card,
    .landing-card-back {
      width: min(100%, 21rem);
      min-height: 27.6rem;
      border-radius: 1.8rem;
      transform-origin: 50% 82%;
    }

    .landing-card-back {
      position: absolute;
      border: 1px solid rgba(255, 255, 255, 0.95);
      box-shadow: 0 20px 50px rgba(104, 74, 74, 0.08);
    }

    .landing-card-back-one {
      transform: translate(-0.75rem, 0.9rem) rotate(-8deg);
      background: #f6efea;
    }

    .landing-card-back-two {
      transform: translate(0.8rem, 0.65rem) rotate(7deg);
      background: #fff2f5;
    }

    .landing-card {
      position: relative;
      z-index: 2;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      gap: 0.58rem;
      padding: 1rem;
      background:
        radial-gradient(circle at 12% 18%, rgba(255, 197, 217, 0.34), transparent 24%),
        radial-gradient(circle at 88% 18%, rgba(232, 216, 205, 0.48), transparent 22%),
        linear-gradient(180deg, #fffdfb 0%, #fff2f5 100%);
      border: 1px solid rgba(255, 255, 255, 0.98);
      box-shadow: 0 28px 80px rgba(104, 74, 74, 0.15);
    }

    .landing-card.is-sliding {
      animation: landing-card-slide 280ms ease;
    }

    .landing-card-brand {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      color: var(--color-base-500);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .landing-card-logo {
      width: 7.2rem;
      height: auto;
      object-fit: contain;
    }

    .landing-card-character {
      display: block;
      width: 5rem;
      height: 5rem;
      object-fit: contain;
      margin: 0.1rem auto 0;
      filter: drop-shadow(0 12px 20px rgba(104, 74, 74, 0.12));
    }

    .landing-card-mode {
      margin-top: 0.1rem;
      color: var(--color-rose-700);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    .landing-card-question {
      margin-top: 0;
      color: var(--color-base-900);
      font-family: "Newsreader", ui-serif, Georgia, serif;
      font-size: clamp(1.42rem, 3.35vw, 1.92rem);
      font-weight: 500;
      line-height: 1.01;
      overflow-wrap: anywhere;
    }

    .landing-card-note {
      margin-top: auto;
      border-radius: 1.2rem;
      background: rgba(255, 255, 255, 0.78);
      padding: 0.78rem 0.9rem;
      box-shadow: 0 10px 24px rgba(104, 74, 74, 0.06);
    }

    .landing-card-note p {
      color: var(--color-base-500);
      font-size: 0.64rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .landing-card-note span {
      margin-top: 0.35rem;
      display: block;
      color: var(--color-base-800);
      font-size: 0.88rem;
      line-height: 1.3;
      overflow-wrap: anywhere;
    }

    .landing-deck-toolbar {
      position: absolute;
      z-index: 4;
      top: 0.05rem;
      bottom: auto;
      left: 50%;
      display: flex;
      gap: 0.4rem;
      transform: translateX(-50%);
    }

    .landing-deck-nav {
      position: static;
      display: inline-flex;
      min-height: 2.05rem;
      min-width: 3.45rem;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.72);
      padding: 0.42rem 0.64rem;
      color: var(--color-base-700);
      font-size: 0.78rem;
      font-weight: 600;
      box-shadow: 0 10px 24px rgba(104, 74, 74, 0.06);
      transition: transform 160ms ease, background-color 160ms ease;
    }

    .landing-deck-toolbar > .landing-deck-nav {
      position: static;
      inset: auto;
      transform: none;
    }

    .landing-deck-nav:hover {
      transform: translateY(-1px);
      background: white;
    }

    .landing-deck-toolbar > .landing-deck-nav:hover {
      transform: translateY(-1px);
    }

    .landing-deck-nav-next {
      background: rgba(255, 255, 255, 0.86);
      color: var(--color-base-900);
    }

    .landing-deck-nav-next:hover {
      background: white;
    }

    @keyframes landing-card-slide {
      0% {
        transform: translateY(0.65rem) rotate(-2deg) scale(0.985);
      }
      100% {
        transform: translateY(0) rotate(0deg) scale(1);
      }
    }

    @media (max-width: 640px) {
      .landing-deck-stage {
        min-height: 29.5rem;
      }

      .landing-card,
      .landing-card-back {
        min-height: 28rem;
      }

      .landing-card-question {
        font-size: clamp(1.35rem, 6.4vw, 1.75rem);
      }
    }
  </style>
</BaseLayout>
