---
export const prerender = false;

import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { DEFAULT_PRODUCT } from "@/lib/products";
import heroScene from "@/images/mascots/mochi-mates/mochi-mallow-hero-scene.png";

const featuredProduct = {
  name: DEFAULT_PRODUCT.name,
  price: "$29",
};

const trustDetails = [
  "120 prompts",
  "$29 once",
  "Private account access",
  "Secure Stripe checkout",
];

const useCases = [
  {
    title: "Check in",
    desc: "Name what felt good, what felt hard, and what you need next.",
  },
  {
    title: "Reconnect",
    desc: "Restart gently after a busy week, a long day, or distance.",
  },
  {
    title: "Go deeper",
    desc: "Move beyond default conversation without making the night heavy.",
  },
];

const productPreviews = [
  {
    label: "Tonight's card",
    title: "What made you feel most supported by me this week?",
    detail: "Answer, add one follow-up, then swap turns.",
  },
  {
    label: "Reset mode",
    title: "What are we carrying into tonight that we don't want to keep carrying?",
    detail: "A gentle way to reset before things turn into distance.",
  },
  {
    label: "Future mode",
    title: "What would make next week feel softer, lighter, or more us?",
    detail: "End with one tiny promise you can actually keep.",
  },
];

const testimonials = [
  {
    quote: "It gives us a better starting point than small talk. We actually use it instead of just meaning to reconnect.",
    author: "A + J · serious dating",
  },
];

const faqs = [
  {
    q: "Is this a physical product?",
    a: "No. Love Alaoui is a digital experience you unlock online and revisit whenever you want.",
  },
  {
    q: "How do we access it?",
    a: "You sign in to your account and open your private deck inside My Deck after purchase.",
  },
  {
    q: "Can we use it on our phones?",
    a: "Yes. The experience is designed mobile-first so it feels natural on the sofa, at dinner, or from long distance.",
  },
  {
    q: "Who is it for?",
    a: "Serious dating, engaged, married, and long-distance couples who want better conversations without pressure or therapy-speak.",
  },
  {
    q: "When should we use it?",
    a: "Date nights, weekly check-ins, after a tense week, or any evening when you want to feel more intentional together.",
  },
];

const title = "Love Alaoui | The Better Conversations Deck for Couples";
const description = "A one-time-purchase digital conversation deck for couples who want warmer date nights, easier check-ins, and more meaningful conversations without awkward starts.";
---

<BaseLayout title={title} description={description} canonicalPath="/">
  <div class="space-y-12 py-6 pb-24 sm:space-y-14 sm:py-8 lg:space-y-20 lg:py-10">
    <section class="relative overflow-hidden rounded-[2rem] bg-[linear-gradient(180deg,rgba(255,250,247,0.95),rgba(255,244,247,0.92))] shadow-[0_28px_90px_rgba(216,160,168,0.16)] ring-1 ring-white/80" aria-labelledby="hero-title">
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_22%,rgba(255,189,215,0.24),transparent_18%),radial-gradient(circle_at_82%_16%,rgba(219,235,216,0.22),transparent_16%),radial-gradient(circle_at_72%_78%,rgba(255,228,192,0.18),transparent_20%)]"></div>
      <div class="grid gap-8 px-5 py-8 md:grid-cols-[minmax(0,1fr)_minmax(18rem,.82fr)] md:items-center md:px-8 md:py-10 lg:px-10 lg:py-12">
        <div class="space-y-6">
          <p class="text-xs font-medium uppercase tracking-[0.24em] text-rose-700">120-prompt digital deck</p>
          <h1 id="hero-title" class="font-editorial max-w-[9ch] text-[clamp(3.15rem,7vw,5.4rem)] font-medium leading-[0.92] text-base-900">
            Better conversations for couples.
          </h1>
          <p class="max-w-[28rem] text-base leading-relaxed text-base-700">
            Date nights, check-ins, and the moments that need a softer start.
          </p>

          <div class="flex flex-wrap gap-3">
            <a href="/signup?next=/my-deck" class="inline-flex h-12 items-center justify-center rounded-full bg-rose-600 px-6 text-sm font-medium text-white shadow-[0_14px_30px_rgba(225,139,166,0.34)] transition hover:bg-rose-700">
              Sign up & unlock
            </a>
          </div>

        </div>

        <div class="relative mx-auto hidden w-full max-w-[27rem] md:block">
          <div class="absolute inset-x-14 top-10 h-[64%] rounded-full bg-rose-200/35 blur-3xl"></div>
          <div class="relative ml-auto w-[82%] rounded-[2rem] bg-white/58 px-7 py-8 ring-1 ring-white/90 shadow-[0_24px_64px_rgba(216,160,168,0.16)] backdrop-blur">
            <Image src={heroScene} alt="" class="mx-auto w-full max-w-[14rem] object-contain drop-shadow-[0_14px_26px_rgba(215,154,167,0.18)]" loading="eager" aria-hidden="true" />
          </div>
        </div>
      </div>
    </section>

    <section id="featured-product" class="rounded-[2rem] bg-white/80 px-5 py-5 shadow-[0_18px_50px_rgba(216,160,168,0.10)] ring-1 ring-white sm:px-7" aria-label="Product facts">
        <div class="grid grid-cols-2 gap-3 text-center text-sm font-medium text-base-800 md:flex md:flex-wrap md:items-center md:justify-center md:gap-x-6 md:gap-y-2">
          {trustDetails.map((detail) => (
            <span>{detail}</span>
          ))}
        </div>
    </section>

    <section id="how-it-works" class="rounded-[2rem] bg-white px-5 py-9 shadow-sm ring-1 ring-base-100 sm:px-7 lg:px-10 lg:py-12" aria-labelledby="how-heading">
      <div class="mx-auto max-w-4xl text-center">
        <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">How it fits</p>
        <h2 id="how-heading" class="font-editorial mx-auto mt-3 max-w-3xl text-[clamp(2rem,4.5vw,3.2rem)] font-medium leading-[0.98] text-base-900">
          Use it when the moment needs a better start.
        </h2>
      </div>

      <div class="mx-auto mt-8 grid max-w-5xl gap-5 md:grid-cols-3">
        {useCases.map((item) => (
          <article class="border-t border-base-200 pt-4 text-left md:text-center">
            <h3 class="text-lg font-semibold text-base-900">{item.title}</h3>
            <p class="mx-auto mt-2 max-w-xs text-sm leading-relaxed text-base-700">{item.desc}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="preview" class="space-y-4" aria-labelledby="preview-heading">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">Preview</p>
          <h2 id="preview-heading" class="mt-2 text-[clamp(1.45rem,3.5vw,2rem)] font-semibold text-base-900">A prompt, a follow-up, a small next step.</h2>
        </div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 lg:gap-4">
        {productPreviews.map((card) => (
          <article class="rounded-[1.5rem] bg-white p-5 shadow-sm ring-1 ring-base-100">
            <p class="text-xs font-medium uppercase tracking-[0.2em] text-rose-700">{card.label}</p>
            <h3 class="mt-3 text-base font-medium text-base-900">{card.title}</h3>
            <p class="mt-3 text-sm text-base-600">{card.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="rounded-[2rem] bg-white p-6 ring-1 ring-base-100 sm:p-8" aria-labelledby="social-proof-heading">
      <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">Early feedback</p>
      {testimonials.map((item) => (
        <blockquote class="mt-3 max-w-3xl">
          <p id="social-proof-heading" class="font-editorial text-[clamp(1.8rem,4vw,2.7rem)] leading-tight text-base-900">“{item.quote}”</p>
          <footer class="mt-4 text-xs uppercase tracking-[0.16em] text-base-500">{item.author}</footer>
        </blockquote>
      ))}
    </section>

    <section id="faq" class="space-y-4" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-[clamp(1.45rem,3.5vw,2rem)] font-semibold text-base-900">FAQ</h2>
      <div class="space-y-2">
        {faqs.map((item) => (
          <details class="rounded-2xl bg-white p-4 shadow-sm ring-1 ring-base-100">
            <summary class="cursor-pointer list-none pr-6 text-sm font-medium text-base-900">{item.q}</summary>
            <p class="mt-2 text-sm leading-relaxed text-base-700">{item.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section id="final-cta" class="rounded-[2rem] bg-base-900 px-5 py-10 text-center text-white sm:px-7 lg:px-10" aria-labelledby="final-cta-heading">
      <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-200">Ready to feel closer this week?</p>
      <h2 id="final-cta-heading" class="mx-auto mt-3 max-w-2xl text-[clamp(1.45rem,4vw,2.25rem)] font-semibold leading-tight">
        Start with one deck and make closeness easier to begin again.
      </h2>
      <p class="mx-auto mt-3 max-w-2xl text-sm text-rose-100">
        Unlock {featuredProduct.name} once and give yourselves a private conversation ritual you can return to whenever the week needs more care.
      </p>
      <a
        href="/signup?next=/my-deck"
        class="mt-5 inline-flex h-11 items-center justify-center rounded-full bg-white px-6 text-sm font-medium text-base-900 transition hover:bg-base-100"
      >Sign up & unlock · {featuredProduct.price}</a>
    </section>
  </div>

  <div class="fixed inset-x-0 bottom-0 z-20 border-t border-base-200 bg-white/95 p-3 shadow-[0_-8px_24px_rgba(45,30,30,.06)] backdrop-blur sm:hidden">
    <a
      href="/signup?next=/my-deck"
      class="inline-flex h-11 w-full items-center justify-center rounded-full bg-base-900 px-6 text-sm font-medium text-white"
    >Sign up & unlock · {featuredProduct.price}</a>
  </div>
</BaseLayout>
