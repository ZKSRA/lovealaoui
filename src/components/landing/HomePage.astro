---
const featuredProduct = {
  name: "Couples Conversation Deck",
  subtitle: "120 guided prompts for date nights, weekly check-ins, and everyday connection.",
  price: "$29",
  supporting: "One-time purchase · Instant access",
  highlights: [
    "Playful, reflective, and future-focused cards",
    "Quick 5-minute mode + longer date-night flow",
    "Save favorite prompts and reuse every week",
  ],
};

const trustBadges = ["Instant digital access", "Phone-first design", "Long-distance friendly"];

const howItWorks = [
  {
    title: "Discover",
    desc: "You find a deck from TikTok and land here in seconds.",
  },
  {
    title: "Buy",
    desc: "Checkout once and get your private link right away by email.",
  },
  {
    title: "Use together",
    desc: "Open on your phones, take turns, and build a ritual that feels natural.",
  },
];

const benefits = [
  {
    title: "Closer conversations",
    desc: "Prompts are thoughtful and simple, so you can connect without awkward starts.",
  },
  {
    title: "Intentional quality time",
    desc: "Turn ordinary evenings into meaningful check-ins you can actually sustain.",
  },
  {
    title: "Easy to come back to",
    desc: "Use the same deck again and again for date night, reset moments, or weekly reflection.",
  },
];

const productPreviews = [
  {
    label: "Tonight's card",
    title: "What made you feel most supported by me this week?",
    detail: "Add one follow-up and switch turns.",
  },
  {
    label: "Date-night mode",
    title: "Pick a vibe: playful, deeper, or future plans",
    detail: "The deck adapts to your mood in one tap.",
  },
  {
    label: "Weekly check-in",
    title: "Connection score: where are we today?",
    detail: "End with one tiny action for the week ahead.",
  },
];

const testimonials = [
  {
    quote: "Our evenings feel calmer now. We talk with more care instead of defaulting to small talk.",
    author: "A + J · serious dating",
  },
  {
    quote: "Beautifully simple. It made our Sunday check-in feel intentional, not forced.",
    author: "M + R · married",
  },
  {
    quote: "Perfect for date night when we want closeness without overplanning.",
    author: "K + D · engaged",
  },
];

const faqs = [
  {
    q: "Is this a physical product?",
    a: "No. Everything is digital and delivered instantly after checkout.",
  },
  {
    q: "How do we access it?",
    a: "You'll receive a private link by email right after purchase.",
  },
  {
    q: "Can we use it on our phones?",
    a: "Yes. It's designed mobile-first with tap-friendly cards and clear spacing.",
  },
  {
    q: "Is it good for date night?",
    a: "Absolutely. It's built for date nights, quick weekday check-ins, and everything in between.",
  },
  {
    q: "Is it suitable for married / engaged / serious couples?",
    a: "Yes. The prompts are designed for committed couples across different stages.",
  },
];
---

<div class="space-y-10 py-6 pb-24 sm:space-y-12 sm:py-8 lg:space-y-16 lg:py-10">
  <section class="rounded-2xl border border-rose-200/70 bg-rose-50/80 px-4 py-3 text-center shadow-sm sm:px-6">
    <p class="text-xs font-medium tracking-wide text-base-800">
      New: <span class="text-rose-700">Weekend Connection Pack</span> included this month
    </p>
  </section>

  <section class="rounded-[2rem] bg-white/95 p-5 shadow-sm ring-1 ring-base-100 sm:p-7 lg:p-10" aria-labelledby="hero-title">
    <div class="grid items-center gap-6 lg:grid-cols-[1.05fr_.95fr] lg:gap-8">
      <div class="space-y-5">
        <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">Digital tools for couples</p>
        <h1 id="hero-title" class="text-[clamp(2rem,8vw,3.65rem)] font-semibold leading-[1.04] text-base-900">
          Better conversations.<br />
          More connected nights.
        </h1>
        <p class="max-w-xl text-[0.98rem] leading-relaxed text-base-700">
          A soft, premium collection of mobile-first relationship tools that help you create intentional quality time in minutes.
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href="#featured-product"
            class="inline-flex h-11 items-center justify-center rounded-full bg-base-900 px-6 text-sm font-medium text-white transition hover:bg-base-800"
          >Get the Conversation Deck</a>
          <a
            href="#preview"
            class="inline-flex h-11 items-center justify-center rounded-full border border-base-300 bg-base-50 px-6 text-sm font-medium text-base-900 transition hover:bg-base-100"
          >See the preview</a>
        </div>

        <ul class="grid gap-2 text-xs text-base-700 sm:grid-cols-3 sm:gap-3" aria-label="Trust badges">
          {trustBadges.map((badge) => (
            <li class="rounded-full bg-base-50 px-3 py-1.5 ring-1 ring-base-200">✓ {badge}</li>
          ))}
        </ul>
      </div>

      <div class="rounded-3xl bg-gradient-to-br from-rose-100/70 via-rose-50 to-base-50 p-4 shadow-inner ring-1 ring-rose-100 sm:p-5">
        <div class="mx-auto max-w-sm space-y-3 rounded-3xl bg-white p-4 shadow-sm ring-1 ring-base-100">
          <p class="text-xs font-medium uppercase tracking-widest text-rose-700">Conversation Card</p>
          <p class="rounded-2xl bg-base-50 p-4 text-sm leading-relaxed text-base-800">
            “What's one thing we can do this week to feel a little more connected?”
          </p>
          <div class="flex items-center justify-between text-xs text-base-600">
            <span>Card 34 of 120</span>
            <span>Swipe for next →</span>
          </div>
          <div class="rounded-2xl bg-rose-50 px-3 py-2 text-xs text-rose-800 ring-1 ring-rose-100">
            Includes weekly check-ins + date-night modes
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="featured-product" class="rounded-[2rem] bg-base-50 p-5 ring-1 ring-base-100 sm:p-7 lg:p-10" aria-labelledby="featured-heading">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div class="max-w-2xl">
        <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-700">Featured product</p>
        <h2 id="featured-heading" class="mt-2 text-[clamp(1.55rem,4vw,2.2rem)] font-semibold text-base-900">{featuredProduct.name}</h2>
        <p class="mt-2 text-sm text-base-700">{featuredProduct.subtitle}</p>
      </div>
      <div class="rounded-2xl bg-white px-4 py-3 text-right ring-1 ring-base-200">
        <p class="text-xs uppercase tracking-[0.16em] text-base-500">One-time payment</p>
        <p class="text-2xl font-semibold text-base-900">{featuredProduct.price}</p>
        <p class="text-xs text-base-500">{featuredProduct.supporting}</p>
      </div>
    </div>

    <ul class="mt-5 space-y-2 text-sm text-base-800">
      {featuredProduct.highlights.map((item) => <li>• {item}</li>)}
    </ul>

    <div class="mt-5 grid gap-3 sm:grid-cols-2">
      <a
        href="/signup?next=/my-deck"
        class="inline-flex h-11 items-center justify-center rounded-full bg-rose-700 px-5 text-sm font-medium text-white transition hover:bg-rose-800"
      >Buy now · {featuredProduct.price}</a>
      <a
        href="#faq"
        class="inline-flex h-11 items-center justify-center rounded-full border border-base-300 bg-white px-5 text-sm font-medium text-base-900 transition hover:bg-base-50"
      >Read FAQ first</a>
    </div>
  </section>

  <section id="how-it-works" class="space-y-4" aria-labelledby="how-heading">
    <h2 id="how-heading" class="text-[clamp(1.45rem,3.5vw,2rem)] font-semibold text-base-900">How it works</h2>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 lg:gap-4">
      {howItWorks.map((step, index) => (
        <article class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-base-100">
          <p class="text-xs font-medium uppercase tracking-[0.2em] text-rose-700">Step {index + 1}</p>
          <h3 class="mt-2 text-lg font-medium text-base-900">{step.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-base-700">{step.desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="space-y-4 rounded-[2rem] bg-white p-5 shadow-sm ring-1 ring-base-100 sm:p-7 lg:p-8" aria-labelledby="benefits-heading">
    <h2 id="benefits-heading" class="text-[clamp(1.45rem,3.5vw,2rem)] font-semibold text-base-900">Why couples keep using it</h2>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 lg:gap-4">
      {benefits.map((benefit) => (
        <article class="rounded-2xl bg-base-50 p-5 ring-1 ring-base-100">
          <h3 class="text-base font-medium text-base-900">{benefit.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-base-700">{benefit.desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="preview" class="space-y-4" aria-labelledby="preview-heading">
    <h2 id="preview-heading" class="text-[clamp(1.45rem,3.5vw,2rem)] font-semibold text-base-900">Product preview</h2>
    <p class="max-w-xl text-[0.98rem] leading-relaxed text-base-700">
      Designed like a mini app experience: calm interface, smooth hierarchy, and cards that feel premium on mobile.
    </p>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 lg:gap-4">
      {productPreviews.map((card) => (
        <article class="rounded-3xl bg-gradient-to-b from-white to-rose-50 p-5 shadow-sm ring-1 ring-rose-100">
          <p class="text-xs font-medium uppercase tracking-[0.2em] text-rose-700">{card.label}</p>
          <h3 class="mt-3 text-base font-medium text-base-900">{card.title}</h3>
          <p class="mt-3 text-sm text-base-600">{card.detail}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="space-y-4 rounded-[2rem] bg-base-50 p-5 ring-1 ring-base-100 sm:p-7 lg:p-8" aria-labelledby="social-proof-heading">
    <h2 id="social-proof-heading" class="text-[clamp(1.45rem,3.5vw,2rem)] font-semibold text-base-900">Loved by couples</h2>
    <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-3">
      {testimonials.map((item) => (
        <blockquote class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-base-100">
          <p class="text-sm leading-relaxed text-base-800">“{item.quote}”</p>
          <footer class="mt-3 text-xs uppercase tracking-[0.16em] text-base-500">{item.author}</footer>
        </blockquote>
      ))}
    </div>
  </section>

  <section id="faq" class="space-y-4" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="text-[clamp(1.45rem,3.5vw,2rem)] font-semibold text-base-900">FAQ</h2>
    <div class="space-y-2">
      {faqs.map((item) => (
        <details class="rounded-2xl bg-white p-4 shadow-sm ring-1 ring-base-100">
          <summary class="cursor-pointer list-none pr-6 text-sm font-medium text-base-900">{item.q}</summary>
          <p class="mt-2 text-sm leading-relaxed text-base-700">{item.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section id="final-cta" class="rounded-[2rem] bg-base-900 px-5 py-10 text-center text-white sm:px-7 lg:px-10" aria-labelledby="final-cta-heading">
    <p class="text-xs font-medium uppercase tracking-[0.22em] text-rose-200">Ready to feel closer this week?</p>
    <h2 id="final-cta-heading" class="mx-auto mt-3 max-w-xl text-[clamp(1.45rem,4vw,2.1rem)] font-semibold leading-tight">
      Start with one deck and make connection part of your routine.
    </h2>
    <p class="mx-auto mt-3 max-w-xl text-sm text-rose-100">
      Thoughtful prompts, beautiful mobile flow, and meaningful conversations you can revisit any time.
    </p>
    <a
      href="/signup?next=/my-deck"
      class="mt-5 inline-flex h-11 items-center justify-center rounded-full bg-white px-6 text-sm font-medium text-base-900 transition hover:bg-base-100"
    >Get instant access · {featuredProduct.price}</a>
  </section>
</div>

<div class="fixed inset-x-0 bottom-0 z-20 border-t border-base-200 bg-white/95 p-3 shadow-[0_-8px_24px_rgba(45,30,30,.06)] backdrop-blur sm:hidden">
  <a
    href="/signup?next=/my-deck"
    class="inline-flex h-11 w-full items-center justify-center rounded-full bg-base-900 px-6 text-sm font-medium text-white"
  >Get the Deck · {featuredProduct.price}</a>
</div>
